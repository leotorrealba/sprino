{
  "name": "sprino",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation of Tessera (AI-native project state protocol)",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '@sprino/server' dev",
    "build": "bun run --filter '*' build",
    "test": "bun --filter '@sprino/server' test",
    "test:backup": "bash scripts/backup.test.sh",
    "db:migrate": "bun --filter '@sprino/server' db:migrate",
    "db:reset": "bun --filter '@sprino/server' db:reset",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "bun-types": "1.3.13",
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
