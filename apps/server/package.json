{
  "name": "@sprino/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/main.ts",
    "start": "bun src/main.ts",
    "build": "bun build src/main.ts --target bun --outdir dist",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:reset": "bun scripts/reset-db.ts",
    "cleanup-operations": "bun scripts/cleanup-operations.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.0",
    "pg": "^8.13.0",
    "uuid": "^11.0.0",
    "zod": "^3.23.8",
    "@sprino/protocol-types": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.28.0",
    "vitest": "^2.1.0"
  }
}
