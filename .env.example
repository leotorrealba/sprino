# Sprino — local dev configuration
# Copy to .env and adjust. .env is gitignored; .env.example is committed.

# ---------- Database ----------
# Local Postgres via brew: postgres://$USER@localhost:5432/sprino_dev
# Docker Compose dev: postgres://sprino:sprino@localhost:5433/sprino_dev
DATABASE_URL=postgres://USER@localhost:5432/sprino_dev

# ---------- Auth (PoC: per-actor tokens) ----------
# JSON array of { id, kind, display_name, token, agent_runtime? } objects.
# Tokens are passed via Authorization: Bearer <token>.
# Token rotation requires server restart (documented limitation for v0.x).
SPRINO_ACTORS_JSON='[{"id":"018c3e7a-0001-7000-8000-000000000001","kind":"human","display_name":"Leonardo","token":"dev-leo-token-please-change","agent_runtime":null},{"id":"018c3e7a-0001-7000-8000-000000000002","kind":"agent","display_name":"Claude Code (Leo)","token":"dev-claude-token-please-change","agent_runtime":"claude-code","parent_actor_id":"018c3e7a-0001-7000-8000-000000000001"}]'

# ---------- Server ----------
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ---------- Realtime (SSE) ----------
# HMAC secret used to sign short-lived (60s) tickets that authenticate
# EventSource connections to GET /api/events/stream. Required at runtime;
# must be at least 32 characters. Generate with: openssl rand -hex 32
# Rotating it invalidates all in-flight stream tickets — clients reconnect
# and request a new one transparently.
SPRINO_STREAM_SECRET=replace-with-32-or-more-random-bytes-please-change

# ---------- Project bootstrap ----------
# Multiple projects can be seeded on first migration for week 2 multi-repo
# dogfooding. repo_path enables MCP task.create auto-resolution by repo root.
SPRINO_PROJECTS_JSON='[{"id":"018c3e7a-0002-7000-8000-000000000001","slug":"sprino","display_name":"Sprino","repo_path":"/Users/leotorrealba/Development/Sprino"},{"id":"018c3e7a-0002-7000-8000-000000000002","slug":"tessera","display_name":"Tessera","repo_path":"/Users/leotorrealba/Development/tessera"}]'

# Fallback map used by the MCP stdio shim when a repo has no .sprino/project.id.
# Object form maps absolute git top-level path → project id.
SPRINO_REPO_PROJECT_MAP_JSON='{"/Users/leotorrealba/Development/Sprino":"018c3e7a-0002-7000-8000-000000000001","/Users/leotorrealba/Development/tessera":"018c3e7a-0002-7000-8000-000000000002"}'

# Legacy single-project seed. Used only when SPRINO_PROJECTS_JSON is unset.
SPRINO_DEFAULT_PROJECT_SLUG=sprino
SPRINO_DEFAULT_PROJECT_ID=018c3e7a-0002-7000-8000-000000000001

# ---------- Tests ----------
# Tests TRUNCATE before each run, so they refuse to use DATABASE_URL by
# default. Bootstrap a separate test DB:
#   createdb sprino_test
#   cd apps/server && DATABASE_URL=$TEST_DATABASE_URL bun src/db/migrate.ts
# Then run: TEST_DATABASE_URL=... bun --filter @sprino/server test
TEST_DATABASE_URL=postgres://USER@localhost:5432/sprino_test
