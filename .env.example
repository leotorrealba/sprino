# Sprino — local dev configuration
# Copy to .env and adjust. .env is gitignored; .env.example is committed.

# ---------- Database ----------
# Default points at local Postgres started via `brew services start postgresql@15`.
# For Docker Compose dev: postgres://sprino:sprino@localhost:5432/sprino_dev
DATABASE_URL=postgres://leotorrealba@localhost:5432/sprino_dev

# ---------- Auth (PoC: per-actor tokens) ----------
# JSON array of { id, kind, display_name, token, agent_runtime? } objects.
# Tokens are passed via Authorization: Bearer <token>.
# Token rotation requires server restart (documented limitation for v0.x).
SPRINO_ACTORS_JSON='[{"id":"018c3e7a-0001-7000-8000-000000000001","kind":"human","display_name":"Leonardo","token":"dev-leo-token-please-change","agent_runtime":null},{"id":"018c3e7a-0001-7000-8000-000000000002","kind":"agent","display_name":"Claude Code (Leo)","token":"dev-claude-token-please-change","agent_runtime":"claude-code","parent_actor_id":"018c3e7a-0001-7000-8000-000000000001"}]'

# ---------- Server ----------
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ---------- Project bootstrap ----------
# A default project is seeded on first migration if this is set.
SPRINO_DEFAULT_PROJECT_SLUG=sprino
SPRINO_DEFAULT_PROJECT_ID=018c3e7a-0002-7000-8000-000000000001

# ---------- Tests ----------
# Tests TRUNCATE before each run, so they refuse to use DATABASE_URL by
# default. Bootstrap a separate test DB:
#   createdb sprino_test
#   cd apps/server && DATABASE_URL=$TEST_DATABASE_URL bun src/db/migrate.ts
# Then run: TEST_DATABASE_URL=... bun --filter @sprino/server test
TEST_DATABASE_URL=postgres://leotorrealba@localhost:5432/sprino_test
