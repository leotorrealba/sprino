# syntax=docker/dockerfile:1.7
#
# Sprino frontend image.
#
# Multi-stage:
#   1. builder — install deps, run `vite build` to produce static assets.
#   2. runtime — nginx:alpine serving /app/dist and proxying /api + /mcp to
#      the backend service. Single origin keeps cookie/CORS surface flat
#      and means the SPA can fetch('/api/...') with no env-time URL baked
#      into the bundle.

ARG BUN_VERSION=1.3.13
ARG NGINX_VERSION=1.27-alpine

FROM oven/bun:${BUN_VERSION}-alpine AS builder
WORKDIR /app

COPY package.json bun.lock ./
COPY apps/web/package.json apps/web/package.json
COPY apps/server/package.json apps/server/package.json
COPY packages/protocol-types/package.json packages/protocol-types/package.json

RUN bun install --frozen-lockfile

COPY tsconfig.json ./tsconfig.json
COPY packages/protocol-types ./packages/protocol-types
COPY apps/web ./apps/web

RUN cd apps/web && bun run build

# ---

FROM nginx:${NGINX_VERSION} AS runtime

# Replace the default site with our SPA + reverse-proxy config.
RUN rm /etc/nginx/conf.d/default.conf
COPY apps/web/nginx.conf /etc/nginx/conf.d/sprino.conf

COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

EXPOSE 3000

# nginx already handles SIGTERM correctly via its master process.
CMD ["nginx", "-g", "daemon off;"]
